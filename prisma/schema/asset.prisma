model Asset {
  id        String   @id @default(cuid())

  key       String   @unique
  bucket    String

  fileName  String
  mimeType  String?
  sizeBytes Int?
  etag      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ownerId   String
  owner     User     @relation(fields: [ownerId], references: [id])

  chapterReferences  ChapterAssetReference[]
  ebookCoverImages Ebook[]

  @@index([ownerId])
}
