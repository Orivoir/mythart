model User {
  id        String   @id @default(cuid())

  email     String   @unique
  name      String?

  stripeCustomerId String @unique

  subscriptionStatus SubscriptionStatus @default(none)
  plan               PlanType @default(free)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ebooks Ebook[]
  assets Asset[]
}
