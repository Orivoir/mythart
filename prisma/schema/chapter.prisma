model Chapter {
  id        String   @id @default(cuid())
  ebookId   String
  ebook     Ebook    @relation(fields: [ebookId], references: [id])
  content   Json
  title  String
  position Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ebookId])
  @@unique([ebookId, position])
}
