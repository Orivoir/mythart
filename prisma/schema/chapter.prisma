model Chapter {
  id        String   @id @default(cuid())
  content   Json
  title  String
  position Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ebookId   String
  ebook     Ebook    @relation(fields: [ebookId], references: [id])

  assetReferences ChapterAssetReference[]
  collaboratorAccess EbookCollaboratorChapterAccess[]

  @@index([ebookId])
  @@unique([ebookId, position])
}
